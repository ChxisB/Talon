<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.talon.backend</string>

    <key>ProgramArguments</key>
    <array>
        <string>__TALON_BIN_DIR__/talon-server</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TALON_PORT</key>
        <string>8090</string>
        <key>TALON_DATA_DIR</key>
        <string>__TALON_HOME__/data</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>__TALON_HOME__/log/talon-server.log</string>

    <key>StandardErrorPath</key>
    <string>__TALON_HOME__/log/talon-server.err</string>

    <key>WorkingDirectory</key>
    <string>__TALON_HOME__</string>
</dict>
</plist>
