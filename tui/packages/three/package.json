{
  "name": "@tui/three",
  "version": "0.4.1",
  "description": "Three.js WebGPU renderer for OpenTUI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/opentui",
    "directory": "packages/three"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "bun scripts/build.ts",
    "publish": "bun scripts/publish.ts"
