      "import": "./src/runtime-modules.ts"
    }
  },
  "dependencies": {
    "@tui/core": "workspace:*",
    "jimp": "1.6.1",
    "three": "0.185.0"
  },
  "optionalDependencies": {
    "@dimforge/rapier2d-simd-compat": "^0.19.3",
    "bun-webgpu": "0.1.7",
    "planck": "^1.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "@types/three": "0.185.0",
    "commander": "^15.0.0",
    "typescript": "^6"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
